{
  "branches": [
    "main"
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "releaseRules": [
          {
            "type": "revert",
            "release": "patch"
          },
          {
            "breaking": true,
            "release": "major"
          }
        ],
        "parserOpts": {
          "breakingHeaderPattern": "^(\\w*)(?:\\((.*)\\))?!: (.*)$"
        }
      }
    ]
  ]
}
